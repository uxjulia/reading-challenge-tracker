# Copy this file to .env and fill in your values.
# .env is gitignored and will never be committed.

# A long random string used to sign session cookies.
# Generate one with: openssl rand -hex 32
SECRET_KEY=change-me-to-a-long-random-string

# Password required to add, edit, or delete books.
# Anyone can view the bookshelf without a password.
APP_PASSWORD=your-password-here

# Optional Google Books API key (helps avoid rate limiting).
GOOGLE_BOOKS_API_KEY=your-google-api-key-here

# Optional: your name or nickname shown in the header.
USERNAME=your-name-here

# Server settings
PORT=8000

# Frontend dev server origin used for CORS during local development.
CLIENT_ORIGIN=http://localhost:5173
